{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["README.md", "AGENTS.md"],
  "permission": {
    "bash": {
      "*": "ask",

      // Deny commands that have dedicated tools
      "cat *": "deny",
      "curl *": "deny",
      "find *": "deny",
      "grep *": "deny",
      "head *": "deny",
      "tail *": "deny",
      "wget *": "deny",

      // Allow safe read-only commands
      "git diff *": "allow",
      "git log *": "allow",
      "git remote show origin": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "wc *": "allow",
    },
  },
  "mcp": {
    "coding-docs": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
    },
  },
}
