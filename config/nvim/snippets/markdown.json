{
  "Callout": {
    "prefix": ["callout"],
    "body": "> [!${1|NOTE,INFO,WARNING,IMPORTANT,QUESTION|}]\n> ${0}",
    "description": "Insert general callout with selectable type"
  },

  "Links": {
    "prefix": ["l", "link"],
    "body": ["[${1:text}](${2:url}) ${0}"],
    "description": "Add links"
  },

  "Insert code block": {
    "prefix": "codeblock",
    "body": ["```${1:language}", "$0", "```"],
    "description": "Insert fenced code block"
  },

  "Tableflip": {
    "prefix": "tableflip",
    "body": "(╯°□°)╯︵ ┻━┻",
    "description": "Tableflip emoticon"
  },

  "Shrug": {
    "prefix": "shrug",
    "body": "¯\\_(ツ)_/¯",
    "description": "Shrug emoticon"
  }
}
